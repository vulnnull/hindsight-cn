# Hindsight-CN 环境变量配置
# 复制此文件为 .env 并填入你的配置值

# ============================================================
# LLM 配置（必填）
# 支持的提供商: openai, groq, ollama, gemini, anthropic, lmstudio, vertexai, minimax, deepseek, zai, volcano
# ============================================================
HINDSIGHT_API_LLM_PROVIDER=openai
HINDSIGHT_API_LLM_API_KEY=你的API密钥
HINDSIGHT_API_LLM_MODEL=gpt-4o-mini
HINDSIGHT_API_LLM_BASE_URL=https://api.openai.com/v1
# Reasoning effort for providers/models that support it. Examples: low, medium, high, xhigh.
# HINDSIGHT_API_LLM_REASONING_EFFORT=low

# 示例：Anthropic Claude
# HINDSIGHT_API_LLM_PROVIDER=anthropic
# HINDSIGHT_API_LLM_API_KEY=你的anthropic密钥
# HINDSIGHT_API_LLM_MODEL=claude-sonnet-4-20250514

# 示例：Google Vertex AI
# HINDSIGHT_API_LLM_PROVIDER=vertexai
# HINDSIGHT_API_LLM_MODEL=google/gemini-2.0-flash-001
# HINDSIGHT_API_LLM_VERTEXAI_PROJECT_ID=你的GCP项目ID
# HINDSIGHT_API_LLM_VERTEXAI_REGION=us-central1
# HINDSIGHT_API_LLM_VERTEXAI_SERVICE_ACCOUNT_KEY=/path/to/service-account-key.json  # 可选，不设置则使用 ADC

# 示例：MiniMax（支持 100 万上下文窗口）
# HINDSIGHT_API_LLM_PROVIDER=minimax
# HINDSIGHT_API_LLM_API_KEY=你的minimax密钥
# HINDSIGHT_API_LLM_MODEL=MiniMax-M2.7

# 示例：DeepSeek（https://api.deepseek.com）
# HINDSIGHT_API_LLM_PROVIDER=deepseek
# HINDSIGHT_API_LLM_API_KEY=你的deepseek密钥
# HINDSIGHT_API_LLM_MODEL=deepseek-v4-flash  # 或 deepseek-v4-pro / deepseek-chat / deepseek-reasoner

# 示例：智谱 AI GLM 系列（https://z.ai）
# HINDSIGHT_API_LLM_PROVIDER=zai
# HINDSIGHT_API_LLM_API_KEY=你的智谱密钥
# HINDSIGHT_API_LLM_MODEL=glm-4.5-flash  # 或 glm-4.5-air（付费版）

# 示例：LM Studio 本地部署（推荐 Qwen 2.5 32B）
# HINDSIGHT_API_LLM_PROVIDER=lmstudio
# HINDSIGHT_API_LLM_API_KEY=lmstudio
# HINDSIGHT_API_LLM_BASE_URL=http://localhost:1234/v1
# HINDSIGHT_API_LLM_MODEL=qwen2.5-32b-instruct

# ============================================================
# API 配置（可选）
# ============================================================
HINDSIGHT_API_HOST=0.0.0.0
HINDSIGHT_API_PORT=8888
HINDSIGHT_API_LOG_LEVEL=info

# ============================================================
# 反向代理路径（可选）
# 部署在反向代理后面时使用，例如部署到 example.com/hindsight/ 则设置为 "/hindsight"
# ============================================================
# HINDSIGHT_API_BASE_PATH=/hindsight
# NEXT_PUBLIC_BASE_PATH=/hindsight

# ============================================================
# 数据库（可选，默认使用内嵌 pg0）
# ============================================================
# HINDSIGHT_API_DATABASE_URL=postgresql://用户名:密码@主机:5432/数据库名
# HINDSIGHT_API_READ_DATABASE_URL=  # 可选，只读副本 URL。设置后，检索查询通过独立连接池路由到只读端点
# HINDSIGHT_API_MIGRATION_DATABASE_URL=  # 数据库迁移用的直连 URL（绕过 PgBouncer），不设置则使用 DATABASE_URL
# HINDSIGHT_API_DATABASE_SCHEMA=public  # PostgreSQL 模式名（默认：public）

# ============================================================
# 向量扩展（可选，默认使用 pgvector）
# 选项："pgvector"（默认）、"vchord"、"pgvectorscale"（DiskANN）
# ============================================================
# HINDSIGHT_API_VECTOR_EXTENSION=pgvector
# Azure PostgreSQL 使用 DiskANN：
# HINDSIGHT_API_VECTOR_EXTENSION=pgvectorscale  # 自动检测 pg_diskann

# ============================================================
# Embedding 配置（可选，默认使用本地模型）
# 提供商："local"（默认）、"tei"、"openai"、"cohere"、"google"、"openrouter"、"litellm"、"litellm-sdk"
# ============================================================
# HINDSIGHT_API_EMBEDDINGS_PROVIDER=local
# 本地模型（CN 镜像默认使用 bge-small-zh-v1.5）：
# HINDSIGHT_API_EMBEDDINGS_LOCAL_MODEL=BAAI/bge-small-zh-v1.5
# 中国网络 / HuggingFace 访问受限时使用镜像：
# HF_ENDPOINT=https://hf-mirror.com
# TEI 提供商：
# HINDSIGHT_API_EMBEDDINGS_TEI_URL=http://localhost:8080
# OpenAI 兼容 Embedding：
# HINDSIGHT_API_EMBEDDINGS_OPENAI_API_KEY=sk-xxxx
# HINDSIGHT_API_EMBEDDINGS_OPENAI_MODEL=text-embedding-3-small
# HINDSIGHT_API_EMBEDDINGS_OPENAI_BASE_URL=https://api.openai.com/v1
# For ZeroEntropy zembed-1:
# HINDSIGHT_API_EMBEDDINGS_PROVIDER=zeroentropy
# HINDSIGHT_API_EMBEDDINGS_ZEROENTROPY_API_KEY=ze-xxxx
# HINDSIGHT_API_EMBEDDINGS_ZEROENTROPY_MODEL=zembed-1
# HINDSIGHT_API_EMBEDDINGS_ZEROENTROPY_DIMENSIONS=1280
# HINDSIGHT_API_EMBEDDINGS_ZEROENTROPY_ENCODING_FORMAT=float
# HINDSIGHT_API_EMBEDDINGS_ZEROENTROPY_LATENCY=fast
#
# 注意：Embedding 配置键名格式为 HINDSIGHT_API_EMBEDDINGS_{提供商}_{参数}
# 例如 HINDSIGHT_API_EMBEDDINGS_OPENAI_MODEL
#
# DeepSeek 说明：DeepSeek 仅支持 LLM 调用，不支持 Embedding。
# 如使用 DeepSeek 作为 LLM，请将 Embedding 设为 local/openai/cohere/google 等。

# ============================================================
# Reranker 配置（可选，默认使用本地模型）
# 提供商："local"（默认）、"tei"、"none"
# ============================================================
# HINDSIGHT_API_RERANKER_PROVIDER=local
# 本地模型（CN 镜像默认使用 mmarco-mMiniLMv2）：
# HINDSIGHT_API_RERANKER_LOCAL_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
# TEI 提供商：
# HINDSIGHT_API_RERANKER_TEI_URL=http://localhost:8081

# ============================================================
# 可观测性与链路追踪（可选，默认关闭）
# 启用 OpenTelemetry 追踪（GenAI 语义规范）
# ============================================================
# HINDSIGHT_API_OTEL_TRACES_ENABLED=true
#
# 本地开发 - Grafana LGTM 栈（推荐）
# HINDSIGHT_API_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
#
# 云端后端（Grafana Cloud、Langfuse、DataDog 等）
# HINDSIGHT_API_OTEL_EXPORTER_OTLP_ENDPOINT=https://你的后端地址
# HINDSIGHT_API_OTEL_EXPORTER_OTLP_HEADERS="Authorization=Bearer 你的令牌"
#
# 自定义服务名和环境（可选，默认：hindsight-api / development）
# HINDSIGHT_API_OTEL_SERVICE_NAME=hindsight-production
# HINDSIGHT_API_OTEL_DEPLOYMENT_ENVIRONMENT=production

# ============================================================
# 控制面板（可选）
# ============================================================
# 数据面 API 地址 - 控制面板代理请求的目标地址
# HINDSIGHT_CP_DATAPLANE_API_URL=http://localhost:8888

# 可选：设置访问密钥以保护控制面板
# 设置后，访客需在登录页输入密钥才能访问仪表板和 /api/* 路由（/api/health 除外）
# HINDSIGHT_CP_ACCESS_KEY=你的访问密钥
