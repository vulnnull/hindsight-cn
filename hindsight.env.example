# =============================================================================
# Hindsight-CN 配置文件
# =============================================================================
# 复制此文件为 hindsight.env 并修改配置：
#   cp hindsight.env.example hindsight.env
#
# 启动方式：./start.sh
# =============================================================================

# === LLM 配置（必填） =============================================
# 提供商: openai, anthropic, gemini, groq, minimax, ollama, lmstudio, deepseek, zai
HINDSIGHT_API_LLM_PROVIDER=openai
HINDSIGHT_API_LLM_API_KEY=
HINDSIGHT_API_LLM_MODEL=MiniMax-M2.7
HINDSIGHT_API_LLM_BASE_URL=https://api.minimaxi.com/v1

# === 数据库（可选，默认使用内嵌 PostgreSQL） =========================
# 留空则自动启动内嵌数据库，数据存储在 ./data 目录
# HINDSIGHT_API_DATABASE_URL=postgresql://user:password@localhost:5432/hindsight

# === 服务端口 ====================================================
HINDSIGHT_API_PORT=8888
HINDSIGHT_CP_PORT=9999

# === Embedding / Reranker 模型（可选） ==============================
# 默认使用内嵌的中文优化模型（bge-small-zh-v1.5 + mmarco-mMiniLMv2）
# 改用远程 Embedding 服务：
# HINDSIGHT_API_EMBEDDINGS_PROVIDER=openai
# HINDSIGHT_API_EMBEDDINGS_OPENAI_MODEL=text-embedding-3-small
# 关闭 Reranker：
# HINDSIGHT_API_RERANKER_PROVIDER=none

# === 服务开关 ====================================================
HINDSIGHT_ENABLE_API=true
HINDSIGHT_ENABLE_CP=true

# === 高级选项 ====================================================
# 等待外部依赖就绪后再启动（使用外部 LLM/DB 时建议开启）
# HINDSIGHT_WAIT_FOR_DEPS=true
# HINDSIGHT_RETRY_MAX=30
# HINDSIGHT_RETRY_INTERVAL=10
